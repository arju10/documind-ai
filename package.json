{
  "name": "documind-ai",
  "version": "1.0.0",
  "description": "> Upload any PDF and chat with it using AI.   > Powered by RAG, Groq Llama 3, ChromaDB and fully written in TypeScript.",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\" --ignore-path .prettierignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\" --ignore-path .prettierignore",
    "format:client": "cd client && npm run format",
    "format:server": "cd server && npm run format",
    "format:all": "npm run format:client && npm run format:server && npm run format",
    "lint:client": "cd client && npm run lint",
    "lint:server": "cd server && npm run lint",
    "lint": "npm run lint:client && npm run lint:server",
    "prepare": "husky"
  },
  "lint-staged": {
    "client/src/**/*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix --max-warnings 0"
    ],
    "server/src/**/*.ts": [
      "prettier --write",
      "eslint --fix --max-warnings 0"
    ],
    "**/*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arju10/documind-ai.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/arju10/documind-ai/issues"
  },
  "homepage": "https://github.com/arju10/documind-ai#readme",
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3"
  }
}
